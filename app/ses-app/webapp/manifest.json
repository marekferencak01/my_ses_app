{
    "_version": "1.65.0",
    "sap.app": {
        "id": "ses.app",
        "type": "application",
        "title": "Service Entry Sheet",
        "description": "Manage Service Entry Sheets against Purchase Orders",
        "applicationVersion": { "version": "1.0.0" },
        "dataSources": {
            "SESService": {
                "uri": "/ses/",
                "type": "OData",
                "settings": {
                    "odataVersion": "4.0"
                }
            }
        }
    },
    "sap.ui": {
        "technology": "UI5",
        "fullWidth": true,
        "deviceTypes": { "desktop": true, "tablet": true, "phone": false }
    },
    "sap.fiori": {
        "registrationIds": [],
        "archeType": "transactional"
    },
    "sap.ui5": {
        "flexEnabled": true,
        "dependencies": {
            "minUI5Version": "1.120.0",
            "libs": {
                "sap.m"            : {},
                "sap.ui.core"      : {},
                "sap.fe.templates" : {}
            }
        },
        "models": {
            "": {
                "dataSource" : "SESService",
                "preload"    : true,
                "settings": {
                    "synchronizationMode" : "None",
                    "operationMode"       : "Server",
                    "autoExpandSelect"    : true,
                    "earlyRequests"       : true,
                    "groupId"             : "$direct"
                }
            }
        },
        "routing": {
            "routes": [
                {
                    "name"    : "PurchaseOrderList",
                    "target"  : "PurchaseOrderList",
                    "pattern" : ":?query:"
                },
                {
                    "name"    : "PurchaseOrderDetails",
                    "target"  : "PurchaseOrderDetails",
                    "pattern" : "PurchaseOrder(POnumber={POnumber},POitem={POitem}):?query:"
                },
                {
                    "name"    : "SESHeaderDetails",
                    "target"  : "SESHeaderDetails",
                    "pattern" : "PurchaseOrder(POnumber={POnumber},POitem={POitem})/serviceEntrySheets({SESno}):?query:"
                }
            ],
            "targets": {
                "PurchaseOrderList": {
                    "type" : "Component",
                    "id"   : "PurchaseOrderList",
                    "name" : "sap.fe.templates.ListReport",
                    "options": {
                        "settings": {
                            "contextPath" : "/PurchaseOrder",
                            "initialLoad" : false,
                            "navigation"  : {
                                "PurchaseOrder": {
                                    "detail": { "route": "PurchaseOrderDetails" }
                                }
                            }
                        }
                    }
                },
                "PurchaseOrderDetails": {
                    "type" : "Component",
                    "id"   : "PurchaseOrderDetails",
                    "name" : "sap.fe.templates.ObjectPage",
                    "options": {
                        "settings": {
                            "contextPath" : "/PurchaseOrder",
                            "navigation"  : {
                                "serviceEntrySheets": {
                                    "detail": { "route": "SESHeaderDetails" }
                                }
                            }
                        }
                    }
                },
                "SESHeaderDetails": {
                    "type" : "Component",
                    "id"   : "SESHeaderDetails",
                    "name" : "sap.fe.templates.ObjectPage",
                    "options": {
                        "settings": {
                            "contextPath" : "/PurchaseOrder/serviceEntrySheets"
                        }
                    }
                }
            }
        }
    },
    "contentDensities": {
        "compact": true,
        "cozy"   : true
    }
}
