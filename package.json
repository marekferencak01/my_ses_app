{
  "name": "ses-app",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@sap/cds": "^9",
    "@sap/cds-fiori": "^2.3.0",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/ux-ui5-tooling": "^1.25.0"
  },
  "scripts": {
    "start": "cds-serve",
    "start:ui": "cd app/ses-app && ui5 serve --port 8090"
  },
  "ui5": {
    "dependencies": [
      "@sap/ux-ui5-tooling"
    ]
  },
"cds": {
    "server": {
        "port": 4004
    },
    "requires": {
        "middlewares": true
    },
    "[development]": {
        "server": {
            "cors": true
        }
    }
},
  "private": true
}
